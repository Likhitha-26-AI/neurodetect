<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>AI Models — NeuroDetect</title>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/sidebar') %>
  <div class="main">
    <%- include('../partials/topbar', { title: 'AI Model Tracking' }) %>
    <div class="content">
      <% if (messages.success) { %>
        <div class="alert alert-success"><%= messages.success %></div>
      <% } %>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
        <div>
          <div class="section-header">
            <h2>Trained Models</h2>
          </div>
          <table>
            <thead>
              <tr>
                <th>Model Name</th>
                <th>Framework</th>
                <th>Epochs</th>
                <th>Accuracy</th>
                <th>F1 Score</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% models.forEach(m => { %>
              <tr>
                <td><%= m.name %></td>
                <td>
                  <span class="badge <%= m.framework === 'FastAI' ? 'badge-cnn' : m.framework === 'YOLOv5' ? 'badge-yolo' : 'badge-other' %>">
                    <%= m.framework %>
                  </span>
                </td>
                <td><%= m.epochs || '—' %></td>
                <td style="color:#22d3ee; font-weight:600"><%= m.accuracy || '—' %></td>
                <td><%= m.f1Score || '—' %></td>
                <td>
                  <form action="/models/<%= m._id %>?_method=DELETE" method="POST"
                    onsubmit="return confirm('Are you sure you want to delete this model?')">
                    <button class="btn btn-danger">Delete</button>
                  </form>
                </td>
              </tr>
              <% }) %>
              <% if (models.length === 0) { %>
                <tr>
                  <td colspan="6" style="text-align:center; color:#64748b; padding:28px;">
                    No models added yet.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <div>
          <div class="section-header">
            <h2>Add Trained Model</h2>
          </div>
          <div class="form-box">
            <form action="/models" method="POST" enctype="multipart/form-data">
              <div class="form-group">
                <label>Model Name</label>
                <input type="text" name="name" required
                  placeholder="e.g. FastAI CNN Classification Model">
              </div>
              <div class="form-group">
                <label>Framework</label>
                <select name="framework">
                  <option value="FastAI">FastAI</option>
                  <option value="YOLOv5">YOLOv5</option>
                  <option value="PyTorch">PyTorch</option>
                  <option value="Other">Other</option>
                </select>
              </div>
              <div class="form-group">
                <label>Epochs</label>
                <input type="number" name="epochs"
                  placeholder="e.g. 100">
              </div>
              <div class="form-group">
                <label>Accuracy (%)</label>
                <input type="text" name="accuracy"
                  placeholder="e.g. 95.78%">
              </div>
              <div class="form-group">
                <label>Precision</label>
                <input type="text" name="precision"
                  placeholder="e.g. 96.70%">
              </div>
              <div class="form-group">
                <label>Recall</label>
                <input type="text" name="recall"
                  placeholder="e.g. 95.65%">
              </div>
              <div class="form-group">
                <label>F1 Score</label>
                <input type="text" name="f1Score"
                  placeholder="e.g. 96.17%">
              </div>
              <div class="form-group">
                <label>Training Date</label>
                <input type="date" name="trainingDate">
              </div>
              <div class="form-group">
                <label>Upload Model File</label>
                <input type="file" name="modelFile">
              </div>
              <button type="submit" class="btn btn-primary">Add Model</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>